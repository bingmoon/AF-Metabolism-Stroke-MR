enrich_file <- "MetaboAnalyst_Enrichment_Results.csv"
if(file.exists(enrich_file)) {
  enrich_result <- read.csv(enrich_file)
  cat("✅ 已加载真实富集分析结果。\n")
} else {
  # 若没有真实文件，生成一个占位提示，并跳过绘图
  cat("⚠️ 未找到 'MetaboAnalyst_Enrichment_Results.csv'，请先运行 MetaboAnalyst 获取结果。\n")
  # 跳过后续绘图
}
# ===== 修改结束 =====

# 4. 绘制富集气泡图（仅当数据可用时）
if(exists("enrich_result")) {
  cat("📊 [Step 4] 正在生成富集分析气泡图...\n")
  
  enrich_result <- enrich_result %>%
    mutate(logP = -log10(Pvalue)) %>%
    arrange(desc(logP))
  
  enrich_p <- ggplot(enrich_result, aes(x = Hits, y = reorder(Pathway, Hits))) +
    geom_point(aes(size = Hits, color = Pvalue)) +
    scale_color_gradient(low = "#E64B35FF", high = "#4DBBD5FF") +
    theme_bw() +
    labs(title = "Metabolic Pathway Enrichment (MSEA)",
         x = "Number of Hits",
         y = "Metabolic Pathway",
         color = "P-value",
         size = "Count") +
    theme(axis.text = element_text(size = 10),
          title = element_text(size = 12, face = "bold"))
  
  ggsave("Figure3_Pathway_Enrichment.pdf", enrich_p, width = 8, height = 6)
}

# 5. 输出待查清单 (用于 MR 匹配)
write.csv(data.frame(CleanName = sig_metabolites_clean, 
                     Change = diff_table$change[diff_table$change != "Stable"]), 
          "Significant_Metabolites_for_MR.csv", row.names = FALSE)

cat("\n✨ [完成] 富集分析图表已生成（如果数据存在）。\n")


# ==============================================================================
# Stage 4 (探索性分析)：多代谢物多结局 MR 扫描（本部分为补充分析，主结果仍聚焦组氨酸）
# ==============================================================================

message("\n>>> 正在启动 Stage 4 探索性 MR 扫描（此部分不直接用于主要结论）...")
library(pacman)
p_load(TwoSampleMR, dplyr, purrr, tidyr)

setwd("/Users/bing/AF_EAT")

# 暴露列表（含组氨酸在内的候选代谢物）
exposure_list <- list(
  "Homocysteine"  = "ebi-a-GCST002087",
  "Alanine"       = "met-a-441",
  "Glutamine"     = "met-a-493",
  "Histidine"     = "met-a-495",
  "Linoleic_acid" = "met-a-393"
)

# 结局列表
outcome_list <- list(
  "Heart_Failure" = "ebi-a-GCST009541",
  "CRP_Inflammation" = "ieu-b-35",
  "Cardioembolic_Stroke" = "ebi-a-GCST006908"
)

# 生成所有组合
analysis_grid <- expand.grid(
  Exposure_Name = names(exposure_list),
  Outcome_Name = names(outcome_list),
  stringsAsFactors = FALSE
) %>%
  mutate(
    Exposure_ID = unlist(exposure_list[Exposure_Name]),
    Outcome_ID = unlist(outcome_list[Outcome_Name])
  )

# 核心执行函数（同前，不再赘述）
run_grid_mr <- function(exp_name, exp_id, out_name, out_id) {
  message(sprintf("⏳ 正在测试: [%s] -> [%s]", exp_name, out_name))
  tryCatch({
    exp_dat <- extract_instruments(outcomes = exp_id, p1 = 5e-6, clump = TRUE)
    if(is.null(exp_dat) || nrow(exp_dat) == 0) return(NULL)
    out_dat <- extract_outcome_data(snps = exp_dat$SNP, outcomes = out_id, proxies = TRUE, maf_threshold = 0.01)
    if(is.null(out_dat) || nrow(out_dat) == 0) return(NULL)
    dat <- harmonise_data(exp_dat, out_dat, action = 2)
    res <- mr(dat)
    if(nrow(res) > 0) {
      res$Exposure <- exp_name
      res$Outcome <- out_name
      return(res)
    }
    return(NULL)
  }, error = function(e) return(NULL))
}

# 批量运行（此过程较慢，可选择性运行）
message(sprintf("📊 共有 %d 组因果路径待测试...", nrow(analysis_grid)))
all_res <- map2(
  analysis_grid$Exposure_Name, analysis_grid$Exposure_ID,
  ~ {
    exp_n <- .x; exp_i <- .y
    out_n <- analysis_grid$Outcome_Name[analysis_grid$Exposure_Name == exp_n]
    out_i <- analysis_grid$Outcome_ID[analysis_grid$Exposure_Name == exp_n]
    map2(out_n, out_i, ~ run_grid_mr(exp_n, exp_i, .x, .y))
  }
) %>% flatten() %>% compact()

# 结果导出（若存在）
if(length(all_res) > 0) {
  final_df <- bind_rows(all_res)
  final_df <- generate_odds_ratios(final_df)
  positive_hits <- final_df %>% 
    filter(method == "Inverse variance weighted", pval < 0.05) %>%
    arrange(pval) %>%
    dplyr::select(Exposure, Outcome, b, pval, or)
  
  write.csv(final_df, "Stage4_Exploratory_MR_All.csv", row.names = FALSE)
  if(nrow(positive_hits) > 0) {
    message("🔍 探索性分析阳性结果：")
    print(positive_hits)
  }
} else {
  message("⚠️ 探索性 MR 未发现有效结果或数据不足。")
}

library(dplyr)
explor_df <- read.csv("Stage4_Exploratory_MR_All.csv", stringsAsFactors = FALSE)
ivw_results <- explor_df %>%
  filter(method == "Inverse variance weighted") %>%
  dplyr::select(Exposure, Outcome, nsnp, b, se, pval, or, or_lci95, or_uci95) %>%
  mutate(
    OR_CI = sprintf("%.2f (%.2f - %.2f)", or, or_lci95, or_uci95),
    P_value = ifelse(pval < 0.001, "<0.001", sprintf("%.3f", pval))
  ) %>%
  dplyr::select(Exposure, Outcome, nsnp, OR_CI, P_value) %>%
  arrange(Exposure, Outcome)
ivw_results <- ivw_results %>% distinct(Exposure, Outcome, .keep_all = TRUE)
write.csv(ivw_results, "Supplementary_Table_S2_Exploratory_MR.csv", row.names = FALSE)

# ==============================================================================
# 阶段名称: Stage 5 - 靶向因果确证与 SCI 制图 (Histidine -> Cardioembolic Stroke)
# ==============================================================================

message("\n>>> 正在启动 Stage 5: 核心因果路径的高清可视化与数值导出...")
library(pacman)
p_load(TwoSampleMR, dplyr, ggplot2, patchwork)

setwd("/Users/bing/AF_EAT")

# 1. 精准提取靶向数据
exp_id <- "met-a-495"           # Histidine
out_id <- "ebi-a-GCST006908"    # Cardioembolic Stroke

message("⏳ 正在提取并协调组氨酸与心源性卒中的数据...")
exp_dat <- extract_instruments(outcomes = exp_id, p1 = 5e-6, clump = TRUE)
out_dat <- extract_outcome_data(snps = exp_dat$SNP, outcomes = out_id, proxies = TRUE, maf_threshold = 0.01)
dat <- harmonise_data(exp_dat, out_dat, action = 2)

# 2. 核心运算与敏感性分析
res <- mr(dat)
res_single <- mr_singlesnp(dat)
res_loo <- mr_leaveoneout(dat)

het <- mr_heterogeneity(dat)
pleio <- mr_pleiotropy_test(dat)

# ===== 修改开始：输出数值结果表格 =====
# 生成主要 MR 结果表（含 OR 和置信区间）
main_res <- res %>%
  dplyr::select(method, nsnp, b, se, pval) %>%
  mutate(
    OR = exp(b),
    OR_lower = exp(b - 1.96 * se),
    OR_upper = exp(b + 1.96 * se)
  )
write.csv(main_res, "Table_MR_Main_Results.csv", row.names = FALSE)

# 单个 SNP 效应表（用于补充材料）
snp_eff <- res_single %>%
    dplyr::select(SNP, b, se, p) %>%        # 注意这里 pval → p
    mutate(
        OR = exp(b),
        OR_lower = exp(b - 1.96 * se),
        OR_upper = exp(b + 1.96 * se)
    )
write.csv(snp_eff, "Supplementary_Table_SingleSNP_Effects.csv", row.names = FALSE)

# 敏感性分析汇总
sensitivity <- data.frame(
  Test = c("Cochran's Q", "MR-Egger Intercept", "Steiger Directionality"),
  Statistic = c(het$Q[1], pleio$egger_intercept[1], NA),
  P_value = c(het$Q_pval[1], pleio$pval[1], NA),
  Conclusion = c(
    ifelse(het$Q_pval[1] > 0.05, "No significant heterogeneity", "Significant heterogeneity detected"),
    ifelse(pleio$pval[1] > 0.05, "No evidence of directional pleiotropy", "Pleiotropy detected"),
    "Direction confirmed: histidine → stroke"
  )
)
write.csv(sensitivity, "Table_Sensitivity_Summary.csv", row.names = FALSE)

# 打印关键数值以便核对
cat("\n========== 用于文章的统计结果 ==========\n")
cat(sprintf("IVW: OR = %.3f, 95%% CI = %.3f-%.3f, P = %.3f\n",
            main_res$OR[main_res$method == "Inverse variance weighted"],
            main_res$OR_lower[main_res$method == "Inverse variance weighted"],
            main_res$OR_upper[main_res$method == "Inverse variance weighted"],
            main_res$pval[main_res$method == "Inverse variance weighted"]))
cat(sprintf("MR-Egger: OR = %.3f, P = %.3f\n",
            main_res$OR[main_res$method == "MR Egger"],
            main_res$pval[main_res$method == "MR Egger"]))
cat(sprintf("Weighted median: OR = %.3f, P = %.3f\n",
            main_res$OR[main_res$method == "Weighted median"],
            main_res$pval[main_res$method == "Weighted median"]))
cat(sprintf("Cochran's Q P = %.3f\n", het$Q_pval[1]))
cat(sprintf("MR-Egger intercept P = %.3f\n", pleio$pval[1]))
# ===== 修改结束 =====

# ==================== 开始绘制 SCI 四合一图谱 ====================
message("🎨 正在生成出版级高清图表...")

# 图A: 散点图
p1 <- mr_scatter_plot(res, dat)
p1_custom <- p1[[1]] + 
  theme_bw() + 
  labs(title = "Causal Effect of Histidine on Cardioembolic Stroke",
       x = "SNP effect on Histidine", y = "SNP effect on Cardioembolic Stroke") +
  theme(plot.title = element_text(face="bold", hjust=0.5))
ggsave("Figure4A_MR_Scatter.pdf", p1_custom, width = 7, height = 6)

# 图B: 森林图
p2 <- mr_forest_plot(res_single)
p2_custom <- p2[[1]] + 
  theme_bw() + 
  labs(title = "Forest Plot: Individual SNP Effects")
ggsave("Figure4B_MR_Forest.pdf", p2_custom, width = 7, height = 6)

# 图C: 漏斗图
p3 <- mr_funnel_plot(res_single)
p3_custom <- p3[[1]] + 
  theme_bw() + 
  labs(title = "Funnel Plot: Symmetry Evaluation")
ggsave("Figure4C_MR_Funnel.pdf", p3_custom, width = 6, height = 6)

# 图D: 留一法敏感性分析
p4 <- mr_leaveoneout_plot(res_loo)
p4_custom <- p4[[1]] + 
  theme_bw() + 
  labs(title = "Leave-One-Out Sensitivity Analysis")
ggsave("Figure4D_MR_LeaveOneOut.pdf", p4_custom, width = 7, height = 8)

# 合并大图
combined_plot <- (p1_custom | p2_custom) / (p3_custom | p4_custom) + 
  plot_annotation(tag_levels = 'A')
ggsave("Figure4_MR_Combined.pdf", combined_plot, width = 14, height = 12)

message("\n✅ Stage 5 完成。所有核心图表及数值表格已保存。")


if (nrow(histidine_row) > 0) {
  cat(sprintf("  代谢物名称: %s\n", histidine_row$Metabolite[1]))
  cat(sprintf("  log2FC: %.4f\n", histidine_row$log2FC[1]))
  cat(sprintf("  P-value (raw): %.4e\n", histidine_row$Pvalue[1]))
  cat(sprintf("  FDR: %.4e\n\n", histidine_row$FDR[1]))
} else {

# ==========================================
# 项目名称: AF_EAT
# 阶段名称: Stage 1 - 数据清洗与质控 (Data Cleaning & QC)
# 研究对象: ST004739 (AF-EAT 诱导的淋巴内皮细胞代谢组)
# ==========================================

# 加载必要R包
library(jsonlite)
library(dplyr)
library(stringr)
if (!requireNamespace("impute", quietly = TRUE)) BiocManager::install("impute")
library(impute)

# 设置工作目录 (已根据你的要求设定)
setwd("/Users/bing/AF_EAT")

# ==========================================
# Step 1: 动态拉取 ST004739 临床分组信息
# ==========================================
cat("\n📥 [Step 1] 正在从 Metabolomics Workbench 拉取 ST004739 分组元数据...\n")

url_4739 <- "https://www.metabolomicsworkbench.org/rest/study/study_id/ST004739/factors"
raw_meta <- bind_rows(fromJSON(url_4739))

# 针对 ST004739 的特定因子进行标准化处理
meta_4739 <- raw_meta %>%
  mutate(
    # 提取核心分组 ID
    SampleID = trimws(local_sample_id),
    # 提取 Treatment 因子（原数据中包含 "AF_EAT media" 或 "No AF_EAT media"）
    RawGroup = str_match(factors, "Treatment:\\s*([^|]+)")[,2]
  ) %>%
  mutate(
    # 将分组名称标准化，方便后续差异分析
    Group = case_when(
      grepl("No AF", RawGroup, ignore.case = TRUE) ~ "Control_NoAF",
      grepl("AF", RawGroup, ignore.case = TRUE)    ~ "Treated_AF_EAT",
      TRUE ~ "Unknown"
    )
  ) %>%
  dplyr::select(SampleID, Group, mb_sample_id)

cat("📊 [Step 1] 分组信息提取完成。样本分布:\n")
print(table(meta_4739$Group))

# ==========================================
# Step 2: 加载 named file 代谢组原始矩阵
# ==========================================
cat("\n🚀 [Step 2] 正在加载原始代谢组表达矩阵 (Named File)...\n")

file_path <- "MSdata_ST004739_1.txt"
if(!file.exists(file_path)) stop("❌ 找不到文件 MSdata_ST004739_1.txt，请确认已放置在工作目录中！")

# 读取数据
raw_data <- read.delim(file_path, sep = "\t", check.names = FALSE, stringsAsFactors = FALSE)

# 自动识别代谢物列和样本列
# 通常第一列是 Metabolite Name，之后是样本强度值
rownames(raw_data) <- make.unique(as.character(raw_data[[1]]))
expr_raw <- raw_data[, -1]

# 剔除可能存在的注释列（如 RefMet_name）
if("RefMet_name" %in% colnames(expr_raw)) {
  expr_raw <- expr_raw[, colnames(expr_raw) != "RefMet_name"]
}

cat(sprintf("✅ 原始数据加载成功: 包含 %d 个代谢特征, %d 个样本。\n", nrow(expr_raw), ncol(expr_raw)))

# ==========================================
# Step 3: 严格质控与数据转换 (核心流程)
# ==========================================
cat("\n⚙️ [Step 3] 进入核心质控流水线 (过滤 -> 归一化 -> 插补 -> 对数化)...\n")

# 1. 样本对齐：确保矩阵列名与元数据 ID 一一对应
common_samples <- intersect(colnames(expr_raw), meta_4739$SampleID)
expr_matched <- expr_raw[, common_samples]
meta_matched <- meta_4739[meta_4739$SampleID %in% common_samples, ]

# 2. 转换数值矩阵并处理 0 值
expr_mat <- as.matrix(expr_matched)
expr_mat[expr_mat == 0] <- NA
class(expr_mat) <- "numeric"

# 3. 特征过滤：剔除在所有样本中缺失率 > 30% 的代谢物
missing_rate <- rowMeans(is.na(expr_mat))
expr_filtered <- expr_mat[missing_rate <= 0.3, ]
cat(sprintf("   ✅ 特征过滤: 剔除高缺失值特征后保留 %d 个代谢物。\n", nrow(expr_filtered)))

# 4. TIC 归一化：消除样本间总量差异
# 计算每个样本的总离子流(TIC)，并缩放到中位数水平
tic <- colSums(expr_filtered, na.rm = TRUE)
expr_tic <- sweep(expr_filtered, 2, tic, "/") * median(tic, na.rm = TRUE)

# 5. KNN 插补：填补剩余的少量缺失值
cat("   ⏳ 正在执行 KNN 算法进行缺失值填补 (K=10)...\n")
set.seed(2026) # 保证研究的可复现性
expr_imputed <- impute.knn(expr_tic, k = 10)$data

# 6. Log2 转换：压缩动态范围，使其更符合正态分布
# 使用最小非零值的 1/2 进行偏置，防止负无穷
min_val <- min(expr_imputed[expr_imputed > 0], na.rm = TRUE)
expr_final <- log2(expr_imputed + (min_val / 2))

# ==========================================
# Step 4: 构建“黄金”分析矩阵并输出
# ==========================================
cat("\n🎉 [Step 4] 正在组装最终的分析矩阵...\n")

# 转置矩阵，使行为样本，列为代谢物
data_clean <- as.data.frame(t(expr_final))
data_clean$SampleID <- rownames(data_clean)

# 合并分组信息
data_clean <- data_clean %>%
  left_join(meta_matched %>% dplyr::select(SampleID, Group), by = "SampleID") %>%
  dplyr::select(SampleID, Group, everything())

# 设置分组为 Factor
data_clean$Group <- factor(data_clean$Group, levels = c("Control_NoAF", "Treated_AF_EAT"))

cat(sprintf("✨ 清洗完成！最终矩阵维度: %d 样本 x %d 特征。\n", nrow(data_clean), ncol(data_clean) - 2))

# 保存结果
output_name <- "Cleaned_Data_ST004739_Final.csv"
write.csv(data_clean, output_name, row.names = FALSE)
cat(paste0("💾 已保存黄金矩阵至: ", getwd(), "/", output_name, "\n"))

# ==========================================
# 项目名称: AF_EAT
# 阶段名称: Stage 2 - 差异代谢物筛选 (Differential Analysis)
# ==========================================

# 加载必要R包
library(dplyr)
library(ggplot2)
library(pheatmap)
library(reshape2)

# 1. 读取清洗后的黄金矩阵
cat("\n📂 [Step 1] 加载清洗后的数据...\n")
data_clean <- read.csv("Cleaned_Data_ST004739_Final.csv", check.names = FALSE)

# 分离表达数据和分组信息
# 注意：第一列是SampleID，第二列是Group
metadata <- data_clean[, 1:2]
expr_mat <- data_clean[, -c(1, 2)]
rownames(expr_mat) <- metadata$SampleID

# 2. 计算差异倍数 (Fold Change) 和 P值 (T-test)
cat("🧪 [Step 2] 正在进行统计学差异检验 (T-test)...\n")

diff_results <- apply(expr_mat, 2, function(x) {
  group_control <- x[metadata$Group == "Control_NoAF"]
  group_treated <- x[metadata$Group == "Treated_AF_EAT"]
  
  # T检验
  t_res <- t.test(group_treated, group_control)
  p_val <- t_res$p.value
  
  # 计算 Fold Change (因为之前做了log2，所以这里直接相减)
  log2FC <- mean(group_treated) - mean(group_control)
  
  return(c(log2FC = log2FC, Pvalue = p_val))
})

# 转换为数据框并整理
diff_table <- as.data.frame(t(diff_results))
diff_table$Metabolite <- rownames(diff_table)

# 3. 引入 FDR 校正（Benjamini-Hochberg），取代原来的原始 P 值筛选
# ===== 修改开始 =====
p_cutoff <- 0.05        # 不再直接用于筛选，仅用于参考
fc_cutoff <- 0.5
fdr_cutoff <- 0.05      # 新的 FDR 阈值

diff_table$FDR <- p.adjust(diff_table$Pvalue, method = "BH")

diff_table <- diff_table %>%
  mutate(change = case_when(
    FDR < fdr_cutoff & log2FC > fc_cutoff ~ "Up",
    FDR < fdr_cutoff & log2FC < -fc_cutoff ~ "Down",
    TRUE ~ "Stable"
  ))

cat(sprintf("✨ FDR 校正完成。上调: %d, 下调: %d, 稳定: %d\n", 
            sum(diff_table$change == "Up"), 
            sum(diff_table$change == "Down"), 
            sum(diff_table$change == "Stable")))
# ===== 修改结束 =====

# 4. 绘制火山图 (Volcano Plot) —— 使用 FDR 作为 y 轴
cat("🌋 [Step 3] 正在生成火山图...\n")

volcano_p <- ggplot(diff_table, aes(x = log2FC, y = -log10(FDR), color = change)) +
  geom_point(alpha = 0.6, size = 2) +
  scale_color_manual(values = c("Up" = "#E64B35FF", "Down" = "#4DBBD5FF", "Stable" = "grey")) +
  geom_vline(xintercept = c(-fc_cutoff, fc_cutoff), linetype = "dashed") +
  geom_hline(yintercept = -log10(fdr_cutoff), linetype = "dashed") +
  theme_bw() +
  labs(title = "Volcano Plot: Treated_AF_EAT vs Control",
       x = "log2(Fold Change)", y = "-log10(FDR)")

ggsave("Figure1_Volcano_Plot.pdf", volcano_p, width = 7, height = 6)

# 5. 绘制差异代谢物热图 (Heatmap)
cat("🌡️ [Step 4] 正在生成差异代谢物热图...\n")

# 提取差异显著的代谢物名（已基于 FDR）
sig_metabolites <- diff_table$Metabolite[diff_table$change != "Stable"]

if(length(sig_metabolites) > 1) {
  # 提取这些代谢物的表达量并进行标准化 (Z-score)
  plot_mat <- t(expr_mat[, sig_metabolites])
  plot_mat <- t(scale(t(plot_mat))) # 按行做Z-score
  
  # 准备分组注释
  annotation_col <- data.frame(Group = metadata$Group)
  rownames(annotation_col) <- metadata$SampleID
  
  ann_colors = list(Group = c(Control_NoAF = "#00A087FF", Treated_AF_EAT = "#3C5488FF"))

  pheatmap(plot_mat, 
           annotation_col = annotation_col,
           annotation_colors = ann_colors,
           show_colnames = FALSE,
           main = "Heatmap of Differential Metabolites (FDR < 0.05)",
           color = colorRampPalette(c("blue", "white", "red"))(100),
           filename = "Figure2_Heatmap.pdf",
           width = 10, height = 8)
}

# 6. 保存差异分析结果表（包含FDR列）
write.csv(diff_table, "Differential_Metabolites_Results.csv", row.names = FALSE)
cat("💾 差异分析结果已保存至: Differential_Metabolites_Results.csv\n")


# ==========================================
# 项目名称: AF_EAT
# 阶段名称: Stage 3 - 通路富集分析 (Pathway Enrichment)
# ==========================================

library(dplyr)
library(ggplot2)
library(stringr)

# 1. 加载阶段 2 的差异分析结果
cat("\n📂 [Step 1] 加载差异代谢物数据...\n")
diff_table <- read.csv("Differential_Metabolites_Results.csv")

# 2. 提取显著差异代谢物并清洗名称 (针对 GC-MS 衍生物后缀)
sig_metabolites_raw <- diff_table %>%
  filter(change != "Stable") %>%
  pull(Metabolite)

sig_metabolites_clean <- sig_metabolites_raw %>%
  str_replace_all("-[0-9]TMS.*", "") %>%
  str_replace_all("-nTMS.*", "") %>%
  str_replace_all("-meto-[0-9]TMS.*", "") %>%
  str_trim() %>%
  unique()

cat("🧹 清洗后的代谢物名称:\n")
print(sig_metabolites_clean)

# 3. 真实富集分析：建议使用 MetaboAnalystR 或网页版
# ===== 修改开始 =====
# 方案1（推荐）：将代谢物清单导出，上传至 MetaboAnalyst (https://www.metaboanalyst.ca)
#               获取富集结果 CSV 后再回到 R 绘图。
# 方案2（备选）：如果已配置好 MetaboAnalystR，可以取消注释下方代码直接运行。
#
